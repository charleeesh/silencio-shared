{
  "name": "silencio-shared",
  "version": "0.2.1",
  "private": true,
  "description": "Silencio Finance Hub shared design system — AppShell, auth flow, theme provider, design tokens napříč hub/budgeting/cashflow/voicehub.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./assets/logo/silencio-white.png": "./dist/assets/logo/silencio-white.png",
    "./assets/logo/silencio-black.png": "./dist/assets/logo/silencio-black.png",
    "./favicon.ico": "./public/favicon.ico"
  },
  "files": [
    "dist",
    "public/favicon.ico",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --project tsconfig.build.json && tsc-alias --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^2.0.0 || ^3.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^2.5.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-static-copy": "^2.2.0",
    "zod": "^3.24.0"
  }
}
